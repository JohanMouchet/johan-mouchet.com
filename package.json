{
  "name": "johan-mouchet.com",
  "private": true,
  "version": "6.0.0",
  "author": "Johan Mouchet <mouchet.johan@gmail.com>",
  "dependencies": {
    "@storybook/addon-actions": "^5.3.19",
    "@storybook/addon-docs": "^5.3.19",
    "@storybook/addon-knobs": "^5.3.19",
    "@storybook/addon-links": "^5.3.19",
    "@storybook/addon-viewport": "^5.3.19",
    "@storybook/addons": "^5.3.19",
    "@svgr/webpack": "^5.4.0",
    "classnames": "^2.2.6",
    "date-fns": "^2.14.0",
    "dompurify": "^2.0.12",
    "eslint-config-react-app": "^5.2.1",
    "gatsby": "^2.23.12",
    "gatsby-image": "^2.4.9",
    "gatsby-plugin-manifest": "^2.4.14",
    "gatsby-plugin-offline": "^3.2.13",
    "gatsby-plugin-react-helmet": "^3.3.6",
    "gatsby-plugin-sass": "^2.3.12",
    "gatsby-plugin-sharp": "^2.6.14",
    "gatsby-plugin-svgr": "^2.0.2",
    "gatsby-source-filesystem": "^2.3.14",
    "gatsby-transformer-sharp": "^2.5.7",
    "html-react-parser": "^0.13.0",
    "node-sass": "^4.14.1",
    "react": "^16.12.0",
    "react-dom": "^16.12.0",
    "react-helmet": "^6.1.0",
    "typescript": "^3.9.6"
  },
  "devDependencies": {
    "@types/classnames": "^2.2.10",
    "@types/dompurify": "^2.0.2",
    "@types/enzyme": "^3.10.5",
    "@types/jest": "^26.0.4",
    "@typescript-eslint/eslint-plugin": "^3.6.1",
    "@typescript-eslint/parser": "^3.6.1",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-jest": "^23.17.1",
    "eslint-plugin-mdx": "^1.6.9",
    "eslint-plugin-prettier": "^3.1.3",
    "husky": "^4.2.5",
    "lint-staged": "^10.2.4",
    "prettier": "2.0.5",
    "stylelint": "^13.3.3",
    "stylelint-config-prettier": "^8.0.1",
    "stylelint-config-standard": "^20.0.0",
    "stylelint-prettier": "^1.1.2",
    "stylelint-scss": "^3.17.2"
  },
  "scripts": {
    "build": "gatsby build",
    "build:storybook": "build-storybook -c .storybook -o build/storybook",
    "build:all": "gatsby build && npm run build:storybook",
    "develop": "gatsby develop",
    "storybook": "start-storybook -p 9009 -s public",
    "type-check": "tsc --noEmit",
    "lint:js": "eslint src/**/*.{ts,tsx,js,json,mdx}",
    "lint:css": "stylelint src/**/*.scss",
    "format": "npm run lint:js -- --fix && npm run lint:css -- --fix && prettier --write src/**/*.md",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "[disabled]src/**/*.test.{ts,tsx,js}": [
      "npm run test"
    ],
    "src/**/*.{ts,tsx,js,json,mdx}": [
      "eslint --fix"
    ],
    "src/**/*.scss": [
      "stylelint --fix"
    ],
    "src/**/*.md": [
      "prettier --write"
    ]
  }
}
